function main(workbook: ExcelScript.Workbook) {

    // ======== CONFIGURATION ========
    const STATUS_VALUE = "Your Desired Status";

    const COLUMNS_TO_DELETE = [
        "Activity ID",
        "Subject",
        "Created By",
        "Gift Officer",
        "Committed Donor Officer",
        "Account ID"
    ];

    const VALID_US_STATES = new Set([
        "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA",
        "HI", "ID", "IL", "IN", "IA", "KS", "KY", "LA", "ME", "MD",
        "MA", "MI", "MN", "MS", "MO", "MT", "NE", "NV", "NH", "NJ",
        "NM", "NY", "NC", "ND", "OH", "OK", "OR", "PA", "RI", "SC",
        "SD", "TN", "TX", "UT", "VT", "VA", "WA", "WV", "WI", "WY",
        "DC"
    ]);

    // ======== GET DATA ========
    const sheet = workbook.getActiveWorksheet();
    const usedRange = sheet.getUsedRange();
    if (!usedRange) return;

    const values = usedRange.getValues();
    const rowCount = values.length;
    const colCount = values[0].length;

    const headers = values[0].map(h =>
        typeof h === "string" ? h.trim() : ""
    );

    // ======== HELPERS ========
    const getColumnIndex = (name: string): number =>
        headers.findIndex(h => h === name);

    // ======== UPDATE STATUS COLUMN ========
    const statusCol = getColumnIndex("Status");
    if (statusCol !== -1) {
        for (let r = 1; r < rowCount; r++) {
            values[r][statusCol] = STATUS_VALUE;
        }
    }

    // ======== WRITE STATUS CHANGES ========
    usedRange.setValues(values);

  // ======== TRANSFORM "ACCOUNT NAME" HOUSEHOLD VALUES ========
  const accountNameCol = getColumnIndex("Account Name");

  if (accountNameCol !== -1) {
    for (let r = 1; r < rowCount; r++) {
      const cellValue = values[r][accountNameCol];

      if (typeof cellValue === "string" && cellValue.includes("Household")) {

        const openParen = cellValue.indexOf("(");
        const closeParen = cellValue.indexOf(")");

        if (openParen !== -1 && closeParen !== -1 && closeParen > openParen) {

          const insideParens = cellValue
            .substring(openParen + 1, closeParen)
            .trim();

          const beforeParens = cellValue
            .substring(0, openParen)
            .trim();

          values[r][accountNameCol] = `${insideParens} ${beforeParens}`;
        }
      }
    }
  }

    // ======== DELETE COLUMNS (RIGHT → LEFT) ========
    const deleteIndexes = COLUMNS_TO_DELETE
        .map(columnName => getColumnIndex(columnName))
        .filter(i => i !== -1)
        .sort((a, b) => b - a);

    for (const colIndex of deleteIndexes) {
        sheet.getRangeByIndexes(0, colIndex, rowCount, 1).delete(ExcelScript.DeleteShiftDirection.left);
    }

    // ======== RELOAD RANGE AFTER DELETIONS ========
    const refreshedRange = sheet.getUsedRange();
    if (!refreshedRange) return;

    const refreshedValues = refreshedRange.getValues();
    const refreshedHeaders = refreshedValues[0].map(h =>
        typeof h === "string" ? h.trim() : ""
    );

    const billingStateCol = refreshedHeaders.indexOf("Billing State/Province");
    if (billingStateCol === -1) return;

    // ======== HIGHLIGHT INVALID STATES ========
    for (let r = 1; r < refreshedValues.length; r++) {
        const cellValue = refreshedValues[r][billingStateCol];

        if (typeof cellValue !== "string" ||
            !VALID_US_STATES.has(cellValue.trim().toUpperCase())) {

            sheet
                .getRangeByIndexes(r, 0, 1, refreshedValues[0].length)
                .getFormat()
                .getFill()
                .setColor("#F8D7DA"); // light red
        }
    }
}
